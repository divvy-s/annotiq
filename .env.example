# ══════════════════════════════════════════════
# Annotiq — Root Environment Variables
# ══════════════════════════════════════════════
# This is a convenience reference of ALL env vars
# used across the entire project.
#
# Each service has its own .env.example:
#   backend/.env.example   — FastAPI + DB + AI keys
#   frontend/.env.example  — Next.js frontend
#   workers/.env.example   — Celery worker
#
# To get started, copy & fill each one:
#   cp backend/.env.example  backend/.env
#   cp frontend/.env.example frontend/.env
#   cp workers/.env.example  workers/.env

# ── Supabase / PostgreSQL ────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=actual_public_anon_key_here
SUPABASE_SERVICE_KEY=actual_secret_servre
DATABASE_URL=post
# ── OpenAI ───────────────────────────────────
OPENAI_API_KEY=
# ── Cloudinary ───────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── JWT Auth ─────────────────────────────────
JWT_SECRET_KEY=
JWT_ALGORITHM=
JWT_EXPIRE_MINUTES=

# ── Celery & Redis ───────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0

# ── Frontend ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
