# ─────────────────────────────────────────────
# Annotiq Backend — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Supabase / PostgreSQL ────────────────────
# Your Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key (Settings → API → anon / public)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (Settings → API → service_role / secret)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Direct PostgreSQL connection string
# Use the Connection Pooling URL (port 6543) if you're behind IPv6-only networking
DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ── OpenAI ───────────────────────────────────
# Used for generating embeddings (text-embedding-3-small) and AI summaries
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Cloudinary ───────────────────────────────
# Used for storing uploaded meeting audio/video files
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── JWT Authentication ───────────────────────
# Generate a secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-256-bit-hex-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Celery & Redis ───────────────────────────
# Redis broker URL for async task processing
# Use redis://redis:6379/0 when running inside Docker Compose
CELERY_BROKER_URL=redis://localhost:6379/0
