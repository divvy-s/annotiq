# ─────────────────────────────────────────────
# Annotiq Workers — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NOTE: When running via Docker Compose the worker
# automatically mounts the backend/.env file and
# inherits its env vars.  This file is only needed
# if you run the worker manually outside Docker.

# ── Celery & Redis ───────────────────────────
# Redis broker URL for async task processing
# Use redis://redis:6379/0 when running inside Docker Compose
CELERY_BROKER_URL=redis://localhost:6379/0
